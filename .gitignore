# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
*.log

# Data (raw & processed) – large files
data/*.csv
data/*.parquet
data/weather_cache/
data/merged_data.csv

# If you want to keep a small sample CSV, use ! exceptions
# !data/filtered_data_SEARO_1769008875181.csv

# Models & preprocessor artifacts
models/*.joblib
models/*.keras
models/*.h5
models/*.pkl

# Figures & plots
# figures/*.png
figures/*.pdf
figures/*.svg

# Logs
# logs/*.log

# Environment (optional – commit environment.yml but not .env)
.env
.venv
env/

# ============================================================
# Node.js / Next.js (dashboard)
# ============================================================
dashboard/node_modules/
dashboard/.next/
dashboard/out/
dashboard/build/
dashboard/dist/
dashboard/.env.local
dashboard/.env*.local
dashboard/*.log

